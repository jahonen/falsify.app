rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    function onlyAllowedChanges(allowed) {
      return request.resource.data.diff(resource.data).changedKeys().hasOnly(allowed);
    }
    match /users/{userId} {
      allow read: if true;
      allow create: if request.auth != null && request.auth.uid == userId;
      allow update, delete: if request.auth != null && request.auth.uid == userId;
      
      // Follow graph: users/{userId}/following/{targetId}
      match /following/{targetId} {
        // Publicly readable follower/following lists
        allow read: if true;
        // Create only by the owner of the subcollection; prevent self-follow and restrict fields
        allow create: if request.auth != null
          && request.auth.uid == userId
          && targetId != userId
          && request.resource.data.followedId == targetId
          && request.resource.data.keys().hasOnly(["followedId", "createdAt"]);
        // Unfollow only by the owner
        allow delete: if request.auth != null && request.auth.uid == userId;
        // No updates to follow docs
        allow update: if false;
      }
    }

    match /predictions/{predictionId} {
      allow read: if true;
      allow create: if request.auth != null && request.auth.token.email_verified == true;
      allow update, delete: if request.auth != null && request.resource.data.authorId == request.auth.uid && request.auth.token.email_verified == true
        || (
          request.auth != null && request.auth.token.email_verified == true && (
            onlyAllowedChanges(["humanVotes", "updatedAt"]) ||
            onlyAllowedChanges(["comments", "updatedAt"]) ||
            onlyAllowedChanges(["humanVotes", "comments", "updatedAt"]) 
          )
        );
    }

    match /predictions/{predictionId}/comments/{commentId} {
      allow read: if true;
      allow create: if request.auth != null;
      // Optionally restrict update/delete; keep immutable for now
      allow update, delete: if false;
    }

    match /predictions/{predictionId}/votes/{userId} {
      allow read: if true;
      allow create, update, delete: if request.auth != null && request.auth.uid == userId;
    }

    // Direct messages: threads and messages
    match /dms/{threadId} {
      // Only participants can read a thread
      allow read: if request.auth != null && request.auth.uid in resource.data.participants;
      // Create requires the caller to be part of participants (2 users) on write
      allow create: if request.auth != null
        && request.resource.data.participants is list
        && request.resource.data.participants.size() == 2
        && request.auth.uid in request.resource.data.participants;
      // Updates only by participants (e.g., lastMessageAt)
      allow update, delete: if request.auth != null && request.auth.uid in resource.data.participants;
    }

    match /dms/{threadId}/messages/{messageId} {
      function isParticipant() {
        return request.auth != null && request.auth.uid in get(/databases/$(database)/documents/dms/$(threadId)).data.participants;
      }
      allow read: if isParticipant();
      allow create: if isParticipant() && request.resource.data.senderId == request.auth.uid;
      allow update, delete: if false; // immutable messages for now
    }

    // Per-user notifications
    match /users/{userId}/notifications/{notifId} {
      allow read: if request.auth != null && request.auth.uid == userId;
      // Created by backend only
      allow create: if false;
      // Allow user to mark as read; restrict to toggling the 'read' field
      allow update: if request.auth != null && request.auth.uid == userId && onlyAllowedChanges(["read"]);
      allow delete: if false;
    }

    match /comments/{commentId} {
      allow read: if true;
      allow create: if request.auth != null && request.auth.token.email_verified == true;
      allow update, delete: if request.auth != null && request.resource.data.userId == request.auth.uid;
    }

    match /taxonomy/{docId} {
      allow read: if true;
      allow write: if request.auth.token.admin == true;
    }

    // Public leaderboards snapshots (read-only)
    match /leaderboards/{docId} {
      allow read: if true;
      allow write: if false;
    }

    match /{document=**} {
      allow read: if false;
      allow write: if false;
    }
  }
}
